# Sourceress backend local configuration

# Required for encrypting user-stored secrets (e.g., GitHub token)
# Generate something random (at least 32 chars).
APP_SECRET_KEY=

# Optional: GitHub token used if no per-user token is saved
GITHUB_TOKEN=

# Optional: Anthropic API key if you want server-wide default
ANTHROPIC_API_KEY=

# Optional: Pin model
ANTHROPIC_MODEL=

# Optional: Ashby job board (public postings API)
# Find this from https://jobs.ashbyhq.com/<NAME>
ASHBY_JOB_BOARD_NAME=ava-labs
ASHBY_INCLUDE_COMPENSATION=false

# Optional: DB
# DATABASE_URL=sqlite:///./data/app.db
