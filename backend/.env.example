# GitHub token (classic PAT or fine-grained)
GITHUB_TOKEN=

# Optional: default filters
DEFAULT_LOCATION=
DEFAULT_MIN_FOLLOWERS=0
DEFAULT_ACTIVE_DAYS=180

# Database
# Local: SQLite
DB_URL=sqlite:///./data/app.db
# Hosting (Render/etc): Postgres (preferred)
# DATABASE_URL=postgresql://...

# Supabase (magic-link auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Comma-separated allowlist (empty => auth bypass / open local dev)
ALLOWLIST_EMAILS=

# Used to encrypt per-user GitHub tokens at rest (required if you use Settings)
APP_SECRET_KEY=
